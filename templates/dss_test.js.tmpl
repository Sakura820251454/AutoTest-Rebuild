/**
 * DSS 测试脚本模板
 *
 * 此模板由 Python 脚本动态填充配置数据
 * 用于执行 TI C2000 DSP 的 FastRTS 库函数测试
 *
 * 修改说明：支持通过检测 ESTOP0/IDLE 断点判断测试结果
 * - 停在 Right (ESTOP0) = 测试通过
 * - 停在 IDLE = 测试失败
 *
 * 修改说明：支持多时间点内存导出
 * - after_load: 程序烧录后立即导出
 * - before_run: 运行前导出
 * - after_run: 运行完成后导出（默认）
 */

importPackage(Packages.com.ti.debug.engine.scripting);
importPackage(Packages.com.ti.ccstudio.scripting.environment);
importPackage(Packages.java.io);
importPackage(Packages.java.lang);

// ==================== 配置数据（由 Python 注入）====================
var cfg = ${CONFIG_JSON};

// ==================== 全局变量 ====================
var env = ScriptingEnvironment.instance();
var server = null;
var session = null;

// ==================== 初始化调试会话 ====================
function initSession() {
    env.traceBegin(cfg.log_file, "DefaultStylesheet.xsl");
    env.traceSetConsoleLevel(TraceLevel.ALL);
    env.traceSetFileLevel(TraceLevel.ALL);
    
    env.traceWrite(">>> 初始化 DSS 会话...");
    env.traceWrite(">>> CCXML: " + cfg.global.ccxml);
    env.traceWrite(">>> Device: " + cfg.global.device);
    env.traceWrite(">>> CPU: " + cfg.global.cpu);
    
    server = env.getServer("DebugServer.1");
    
    // 先尝试停止任何现有的调试会话（清理残留状态）
    try {
        server.stop();
        env.traceWrite(">>> 已停止现有调试会话");
    } catch (e) {
        // 忽略错误，可能没有现有会话
    }
    
    server.setConfig(cfg.global.ccxml);
    session = server.openSession(cfg.global.device, cfg.global.cpu);
    
    // 尝试连接目标，捕获连接错误
    try {
        session.target.connect();
        env.traceWrite(">>> 连接成功: " + cfg.global.device + "/" + cfg.global.cpu);
    } catch (connectErr) {
        env.traceWrite(">>> 连接失败: " + connectErr.message);
        print("CONNECTION_LOST_DETECTED: " + connectErr.message);
        throw new Error("TARGET_CONNECT_FAILED: " + connectErr.message);
    }
}

// ==================== 格式化十六进制字符串 ====================
function formatHexString(hexString, width) {
    hexString = hexString.replace(/^0x/i, '');
    while (hexString.length < width) {
        hexString = '0' + hexString;
    }
    return hexString;
}

// ==================== 导出内存段 ====================
function exportMemorySegments(testCfg, subdir) {
    var datDir = testCfg.dat_dir + "/" + subdir;
    var f = new java.io.File(datDir);
    if (!f.exists()) f.mkdirs();

    for (var i = 0; i < testCfg.segments.length; i++) {
        var seg = testCfg.segments[i];
        var fname = datDir + "/" + seg.name + ".dat";
        var page = (seg.page !== undefined) ? seg.page : 0;
        env.traceWrite("    保存: " + seg.name + " -> " + fname + " (page " + page + ")");
        try {
            session.memory.saveData2(seg.addr, page, seg.len, fname, seg.width, false);
        } catch (saveErr) {
            env.traceWrite("    警告: 保存失败: " + saveErr.message);
        }
    }
}

// ==================== 获取导出时间点配置 ====================
function getExportConfig(exportPoints) {
    if (!exportPoints || exportPoints.length === 0) {
        return { when: "after_run", enabled: true, subdir: "Memory" };
    }
    // 返回第一个启用的导出点
    for (var i = 0; i < exportPoints.length; i++) {
        var ep = exportPoints[i];
        if (ep.enabled) {
            return ep;
        }
    }
    return exportPoints[0]; // 如果没有启用的，返回第一个
}

// ==================== 检查结果（断点方式） ====================
function checkResultByBreakpoint(testCfg, pc) {
    var successAddr = null;
    var failAddr = null;

    // 获取成功标签地址
    try {
        successAddr = session.symbol.getAddress(testCfg.result_check.success_label);
    } catch (e) {
        env.traceWrite(">>> 警告: 未找到 '" + testCfg.result_check.success_label + "' 符号");
    }

    // 获取失败标签地址
    try {
        failAddr = session.symbol.getAddress(testCfg.result_check.fail_label);
    } catch (e) {
        env.traceWrite(">>> 警告: 未找到 '" + testCfg.result_check.fail_label + "' 符号");
    }

    // 设置断点
    if (successAddr) {
        session.breakpoint.add("0x" + formatHexString(successAddr.toString(16), 4));
        env.traceWrite(">>> 在 " + testCfg.result_check.success_label + " 设置断点");
    }
    if (failAddr) {
        session.breakpoint.add("0x" + formatHexString(failAddr.toString(16), 4));
        env.traceWrite(">>> 在 " + testCfg.result_check.fail_label + " 设置断点");
    }

    // 判断结果
    if (successAddr && pc.toString(16) === successAddr.toString(16)) {
        return "Success";
    } else if (failAddr && pc.toString(16) === failAddr.toString(16)) {
        return "Error";
    } else {
        return "Unknown(0x" + formatHexString(pc.toString(16), 4) + ")";
    }
}

// ==================== 检查结果（内存值方式） ====================
function checkResultByMemory(testCfg) {
    try {
        var addr = parseInt(testCfg.result_check.check_addr, 16);
        var width = testCfg.result_check.check_width || 32;  // 默认读取32位

        // 根据宽度选择读取方式
        var value;
        if (width === 16) {
            value = session.memory.readWord(addr);
        } else {
            // 32位读取：使用readData读取2个16位字并组合
            // DSS readData 签名: readData(page, address, numValues, signed)
            var data = session.memory.readData(0, addr, 2, false);  // page=0, addr=地址, length=2 words
            value = (data[0] << 16) | data[1];  // 高16位在前
        }

        var valueHex = formatHexString(value.toString(16), width === 16 ? 4 : 8);
        env.traceWrite(">>> 读取内存地址 0x" + testCfg.result_check.check_addr + " = 0x" + valueHex + " (" + width + "位)");

        var successVal = parseInt(testCfg.result_check.success_val, 16);
        var failVal = parseInt(testCfg.result_check.fail_val, 16);

        if (value === successVal) {
            return "Success";
        } else if (value === failVal) {
            return "Error";
        } else {
            return "Unknown(0x" + valueHex + ")";
        }
    } catch (e) {
        env.traceWrite(">>> 读取内存失败: " + e.message);
        return "Error:MemoryRead";
    }
}

// ==================== 检查结果（表达式方式） ====================
function checkResultByExpression(testCfg) {
    try {
        var result = session.expression.evaluate(testCfg.result_check.expression);
        env.traceWrite(">>> 表达式结果: " + result);

        if (result.toString() === testCfg.result_check.expected_val) {
            return "Success";
        } else {
            return "Error(" + result + ")";
        }
    } catch (e) {
        env.traceWrite(">>> 表达式评估失败: " + e.message);
        return "Error:Expression";
    }
}

// ==================== 执行单个测试用例 ====================
function runTestCase(testCfg) {
    var result = "Error";
    var timeoutFlag = false;
    var watchdogStopped = false;  // 显式停止标志
    var watchdog = null;
    var startTime = java.lang.System.currentTimeMillis();

    try {
        // 1. 判断是否需要 FLASH 编程（项目名包含 "FLASH"）
        var needFlashProgram = (testCfg.out.toUpperCase().indexOf("FLASH") >= 0);

        if (needFlashProgram) {
            env.traceWrite(">>> 检测到 FLASH 项目，配置 FLASH 编程选项...");
            try {
                // 设置 FLASH 操作：擦除 → 编程 → 验证
                session.flash.options.setString("FlashOperations", "Erase, Program, Verify");
                env.traceWrite(">>> FLASH 操作已配置: Erase, Program, Verify");
            } catch (flashOptErr) {
                env.traceWrite(">>> 警告: 配置 FLASH 选项失败: " + flashOptErr.message);
            }
        }

        env.traceWrite(">>> 加载程序: " + testCfg.out);
        session.memory.loadProgram(testCfg.out);

        // 1.1 如果是 FLASH 项目，验证编程结果
        if (needFlashProgram) {
            try {
                var flashChecksum = session.flash.calculateChecksum();
                env.traceWrite(">>> FLASH 校验和: " + flashChecksum);
            } catch (csErr) {
                env.traceWrite(">>> 警告: FLASH 校验失败: " + csErr.message);
            }

            // 重启目标，使 PC 重新定位到程序入口（FLASH 项目）
            env.traceWrite(">>> 重启目标（FLASH 项目需要重启定位到程序入口）...");
            try {
                session.target.restart();
                java.lang.Thread.sleep(200);
                env.traceWrite(">>> 重启完成");
            } catch (restartErr) {
                env.traceWrite(">>> 警告: 重启失败: " + restartErr.message);
            }
        }

        // 2. 检查加载后的 PC（应该停在 main 入口）
        java.lang.Thread.sleep(100);
        if (session.target.isHalted()) {
            try {
                var pcAfterLoad = session.expression.evaluate("$PC");
                env.traceWrite(">>> 加载后 PC (应在 main): " + pcAfterLoad);
            } catch (e) {
                env.traceWrite(">>> 警告: 无法获取加载后 PC");
            }
        }

        // 获取导出配置
        var exportCfg = getExportConfig(testCfg.export_points);

        // 2.1 导出内存段（烧录后）- 检查初始值
        if (exportCfg.when === "after_load") {
            env.traceWrite(">>> 导出内存段（烧录后）...");
            exportMemorySegments(testCfg, exportCfg.subdir);
        }

        // 注意：不复位目标，直接从 main 入口运行（与 CCS 行为一致）
        session.breakpoint.removeAll();

        // 3. 获取结果判断配置
        var resultCheck = testCfg.result_check || { method: "breakpoint", success_label: "Right", fail_label: "IDLE" };

        // 4. 设置断点（仅断点方式需要）
        if (resultCheck.method === "breakpoint") {
            var successAddr = null;
            var failAddr = null;

            try {
                successAddr = session.symbol.getAddress(resultCheck.success_label);
                env.traceWrite(">>> " + resultCheck.success_label + " 地址: 0x" + formatHexString(successAddr.toString(16), 4));
            } catch (e) {
                env.traceWrite(">>> 警告: 未找到 '" + resultCheck.success_label + "' 符号");
            }

            try {
                failAddr = session.symbol.getAddress(resultCheck.fail_label);
                env.traceWrite(">>> " + resultCheck.fail_label + " 地址: 0x" + formatHexString(failAddr.toString(16), 4));
            } catch (e) {
                env.traceWrite(">>> 警告: 未找到 '" + resultCheck.fail_label + "' 符号");
            }

            if (successAddr) {
                session.breakpoint.add("0x" + formatHexString(successAddr.toString(16), 4));
                env.traceWrite(">>> 在 " + resultCheck.success_label + " 设置断点");
            }
            if (failAddr) {
                session.breakpoint.add("0x" + formatHexString(failAddr.toString(16), 4));
                env.traceWrite(">>> 在 " + resultCheck.fail_label + " 设置断点");
            }
        }

        // 4.1 导出内存段（运行前）- 检查预设数据
        if (exportCfg.when === "before_run") {
            env.traceWrite(">>> 导出内存段（运行前）...");
            exportMemorySegments(testCfg, exportCfg.subdir);
        }

        // 5. 运行程序（超时仅作用于此阶段）
        env.traceWrite(">>> 运行程序...");
        var runStartTime = java.lang.System.currentTimeMillis();

        // 超时监控线程 - 仅监控运行阶段
        watchdog = new java.lang.Thread(function() {
            while (!timeoutFlag && !watchdogStopped) {
                java.lang.Thread.sleep(500);
                if (watchdogStopped) break;  // 再次检查，避免在 sleep 后仍继续
                if (java.lang.System.currentTimeMillis() - runStartTime > testCfg.timeout) {
                    timeoutFlag = true;
                    env.traceWrite(">>> TIMEOUT (" + testCfg.timeout + " ms)");
                    try {
                        if (session && session.target.isConnected()) {
                            session.target.halt();
                        }
                    } catch(e) {}
                    break;
                }
            }
        });
        watchdog.start();

        session.target.run();

        var t0 = java.lang.System.currentTimeMillis();
        while (!session.target.isHalted()) {
            if (timeoutFlag) break;
            java.lang.Thread.sleep(50);
            if (java.lang.System.currentTimeMillis() - t0 > testCfg.timeout) {
                throw new Error("Run timeout");
            }
        }

        // 停止超时监控 - 后续内存导出不受超时限制
        watchdogStopped = true;  // 先设置停止标志
        if (watchdog) {
            watchdog.interrupt();
            watchdog = null;
        }

        if (timeoutFlag) {
            result = "Timeout";
        } else {
            // 7. 根据判断方式检查结果
            if (resultCheck.method === "breakpoint") {
                // 断点方式：获取 PC 并比较
                var pc = null;
                var pcHex = null;

                try {
                    if (session.registers) {
                        pc = session.registers.getPC();
                        pcHex = formatHexString(pc.toString(16), 4);
                        env.traceWrite(">>> 程序停止，PC = 0x" + pcHex);
                    } else {
                        throw new Error("session.registers is undefined");
                    }
                } catch (regErr) {
                    env.traceWrite(">>> 警告: 无法通过 registers 获取 PC: " + regErr.message);

                    try {
                        var pcExpr = session.expression.evaluate("$PC");
                        if (pcExpr) {
                            if (typeof pcExpr === "string") {
                                pc = parseInt(pcExpr, 16);
                            } else if (typeof pcExpr === "number") {
                                pc = pcExpr;
                            } else if (pcExpr.value) {
                                pc = parseInt(pcExpr.value);
                            }
                            pcHex = formatHexString(pc.toString(16), 4);
                        }
                    } catch (exprErr) {
                        result = "Error:CannotGetPC";
                        throw new Error("CannotGetPC");
                    }
                }

                if (pc) {
                    result = checkResultByBreakpoint(testCfg, pc);
                    if (result === "Success") {
                        env.traceWrite(">>> 停在 " + resultCheck.success_label + "，测试通过");
                    } else if (result === "Error") {
                        env.traceWrite(">>> 停在 " + resultCheck.fail_label + "，测试失败");
                    } else {
                        env.traceWrite(">>> 停在未知位置");
                    }
                }
            } else if (resultCheck.method === "memory") {
                // 内存值方式
                result = checkResultByMemory(testCfg);
            } else if (resultCheck.method === "expression") {
                // 表达式方式
                result = checkResultByExpression(testCfg);
            } else {
                env.traceWrite(">>> 错误: 未知的判断方式 " + resultCheck.method);
                result = "Error:UnknownMethod";
            }
        }

        // 8. 导出内存段（运行后）- 此时 test_output 才有数据
        if (exportCfg.when === "after_run") {
            if (result === "Success" || result === "Error" || result.indexOf("Unknown") === 0) {
                env.traceWrite(">>> 导出内存段（运行后）...");
                exportMemorySegments(testCfg, exportCfg.subdir);
            }
        }

    } catch (err) {
        if (!timeoutFlag) {
            result = "Exception:" + err.message;
            env.traceWrite(">>> 异常: " + err.message);
            // 检测连接相关错误，输出到 stdout 供 Python 检测
            var errMsg = err.message ? err.message.toLowerCase() : "";
            if (errMsg.indexOf("connect") >= 0 || errMsg.indexOf("emulation") >= 0 ||
                errMsg.indexOf("ftdi") >= 0 || errMsg.indexOf("xds100") >= 0 ||
                errMsg.indexOf("target") >= 0 || errMsg.indexOf("halt") >= 0) {
                print("CONNECTION_LOST_DETECTED: " + err.message);
            }
        }
    } finally {
        if (watchdog) {
            watchdog.interrupt();
        }
        session.breakpoint.removeAll();
    }

    // 计算耗时（毫秒）
    var endTime = java.lang.System.currentTimeMillis();
    var durationMs = endTime - startTime;

    // 写入结果
    var summary = new java.io.FileWriter(testCfg.dat_dir + "/summary.csv", false);
    summary.write(testCfg.case_name + "," + result + "," + durationMs + "\n");
    summary.close();

    env.traceWrite(">>> 结果: " + result + " (耗时: " + (durationMs / 1000).toFixed(1) + "s)");
    return result;
}

// ==================== 主流程 ====================
var exitCode = 0;
var allResults = [];

try {
    initSession();
    
    for (var i = 0; i < cfg.cases.length; i++) {
        var caseCfg = cfg.cases[i];
        env.traceWrite("");
        env.traceWrite("========================================");
        env.traceWrite(">>> 开始测试: " + caseCfg.case_name + " (" + (i+1) + "/" + cfg.cases.length + ")");
        env.traceWrite("========================================");
        var result = runTestCase(caseCfg);
        env.traceWrite("========================================");
        env.traceWrite(">>> 结束测试: " + caseCfg.case_name + " - 结果: " + result);
        env.traceWrite("========================================");
        env.traceWrite("");
        
        // 收集结果
        allResults.push({name: caseCfg.case_name, result: result});
        
        // 如果有任何用例失败，设置非零退出码
        if (result !== "Success") {
            exitCode = 1;
        }
    }
    
    // 写入汇总文件到时间戳目录
    if (allResults.length > 0) {
        // 从第一个用例的 dat_dir 获取时间戳目录
        var firstDatDir = cfg.cases[0].dat_dir;
        var timeDir = new java.io.File(firstDatDir).getParent();
        var summaryFile = new java.io.FileWriter(timeDir + "/summary.csv", false);
        for (var j = 0; j < allResults.length; j++) {
            summaryFile.write(allResults[j].name + "," + allResults[j].result + "\n");
        }
        summaryFile.close();
        env.traceWrite(">>> 汇总报告已保存: " + timeDir + "/summary.csv");
    }
    
} catch (e) {
    env.traceWrite(">>> 主流程错误: " + e.message);
    exitCode = 2;
} finally {
    if (session && session.target.isConnected()) {
        session.target.disconnect();
    }
    if (server) {
        server.stop();
    }
    env.traceEnd();
}

// 设置退出码
java.lang.System.exit(exitCode);
